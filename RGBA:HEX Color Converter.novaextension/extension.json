{
    "identifier": "p53d.rgba-hex-converter",
    "name": "RGBA/HEX Color Converter",
    "organization": "p53*design",
    "description": "Convert between RGBA and HEX color codes in the editor",
    "version": "1.0.0",
    "repository": "https://github.com/hishida5555/rgba-hex-converter",
    "bugs": "https://github.com/hishida5555/rgba-hex-converter/issues",
    "categories": ["commands"],
    "entitlements": {
        "clipboard": true
    },
    "main": "main.js",
    "config": [
        {
            "key": "p53d.rgba-hex-converter.enableClipboardCommands",
            "title": "Enable Clipboard Conversion (Experimental)",
            "description": "When enabled, allows direct conversion of color codes in the clipboard. Disabled by default for security reasons.",
            "type": "boolean",
            "default": false
        }
    ],
    "commands": {
        "editor": [
            {
                "title": "Convert RGBA to HEX",
                "command": "convertRgbaToHex",
                "shortcut": "ctrl-cmd-h",
                "when": "editorHasFocus && editorHasSelection"
            },
            {
                "title": "Convert HEX to RGBA",
                "command": "convertHexToRgba",
                "shortcut": "ctrl-cmd-r",
                "when": "editorHasFocus && editorHasSelection"
            },
            {
                "title": "Auto-detect and Convert Color Format",
                "command": "autoConvertColor",
                "shortcut": "ctrl-cmd-c",
                "when": "editorHasFocus && editorHasSelection"
            }
        ],
        "extensions": [
            {
                "title": "Clipboard: Convert RGBA to HEX",
                "command": "convertClipboardRgbaToHex",
                "shortcut": "ctrl-cmd-shift-h"
            },
            {
                "title": "Clipboard: Convert HEX to RGBA",
                "command": "convertClipboardHexToRgba",
                "shortcut": "ctrl-cmd-shift-r"
            },
            {
                "title": "Clipboard: Auto-convert Color",
                "command": "convertClipboardAuto",
                "shortcut": "ctrl-cmd-shift-c"
            }
        ]
    }
}
